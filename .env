# SkillPulse Environment Variables
# Copy this file to .env and update the values

# MySQL
MYSQL_ROOT_PASSWORD=rootpassword123
MYSQL_PORT=3306
MYSQL_DATABASE=skillpulse
MYSQL_PASSWORD=skillpulse123
MYSQL_USER=skillpulse

# Docker Hub (used by docker-compose to pull the backend image)
# On EC2, this is appended automatically by Terraform's user_data.
# For local dev, set it to your Docker Hub username (or temporarily flip
# the backend service back to `build: ./backend` while iterating).
DOCKERHUB_USERNAME=rohinidivekar123
